# Copy this file to config/email.env and fill in your Gmail SMTP details.
# Gmail requires an App Password, not your normal account password.
RADAR_EMAIL_TO=your-address@gmail.com
SMTP_USER=your-sender@gmail.com
SMTP_PASSWORD=your-gmail-app-password

# Optional:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# RADAR_EMAIL_FROM=your-sender@gmail.com
# RADAR_EMAIL_SUBJECT_PREFIX=[AI OSS Radar]
# RADAR_ALLOW_SENDMAIL_FALLBACK=false
